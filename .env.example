# =============================================================================
# scripulya_deploy — single source of env/secrets for BOTH run paths.
#
#   cp .env.example .env   then fill in the secrets you need.
#
# Docker Compose reads this file directly.
# Kubernetes reads it once via `make gen-secrets` (scripts/gen-secrets.sh),
# which turns it into the `scripulya-secrets` Secret in-cluster.
#
# !!! SECURITY WARNING !!!
# The sibling source repos contain LEAKED credentials — DO NOT copy them here:
#   * GitHub PAT embedded in both repos' git remotes (ghp_...)
#   * ZAI_API_KEY hardcoded as a default in scripulya_agent/docker-compose.yml
#   * A GEMINI_API_KEY committed in scripulya_ai/.env
# Rotate those at their providers and in the source repos. Generate FRESH keys
# for this file. This repo only ever holds placeholders.
# =============================================================================

# --- scripulya_ai (backend) ---
# Used to sign JWTs. Generate a real one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-secret-change-me

# --- scripulya_agent (LLM worker) ---
# Provider keys are OPTIONAL: leave empty to disable a provider; the agent still
# boots and the backend's "testing_mock" model works fully offline.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Generation defaults (agent) ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- Object storage (MinIO) for media assets ---
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are the minio server's root creds AND the
# backend's S3 access key / secret (one pair, shared). Defaults are local-dev only.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Host embedded in client-facing image URLs — must be reachable FROM the client.
# compose: localhost:9000 (default). k8s NodePort: localhost:30900 (needs a kind
# extraPortMapping for containerPort 30900, or use `make pf`); prod: real DNS.
# A wrong value here makes every image URL 404.
MINIO_PUBLIC_ENDPOINT=localhost:9000
# MINIO_BUCKET_PUBLIC=scripulya-public
# MINIO_BUCKET_PRIVATE=scripulya-private

# --- Misc ---
DEBUG=false

# --- Host port overrides (compose + k8s port-forward) ---
# Defaults avoid clashing with a host-installed RabbitMQ (which owns 5672/15672).
# AI_PORT=8000
# RABBIT_MGMT_PORT=15673
# MINIO_API_PORT=9000       # MinIO S3 API (presigned/public image URLs)
# MINIO_CONSOLE_PORT=9001   # MinIO web console